# CV ATS Maker - Environment Configuration Template
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai

# ========================================
# GEMINI API Configuration
# ========================================

# Dapatkan API key dari: https://aistudio.google.com
# 1. Kunjungi https://aistudio.google.com
# 2. Klik "Create new API key"
# 3. Pilih project dan create API key
# 4. Copy API key dan paste di bawah
GEMINI_API_KEY=your_api_key_here_without_quotes

# ========================================
# Application Settings
# ========================================

# Output directory untuk CV files
OUTPUT_DIRECTORY=cv_output

# Format output (comma-separated): txt, json, pdf, docx
OUTPUT_FORMATS=txt,json

# ========================================
# ATS Optimization Settings
# ========================================

# Aktifkan ATS-friendly formatting
ATS_FRIENDLY_FORMATTING=true

# Hapus special characters
REMOVE_SPECIAL_CHARACTERS=true

# Gunakan action verbs otomatis
USE_ACTION_VERBS=true

# ========================================
# Text Summarization Settings
# ========================================

# Maksimum kata dalam ringkasan
SUMMARY_MAX_LENGTH=150

# Bahasa untuk ringkasan
SUMMARY_LANGUAGE=indonesian

# ========================================
# Logging Settings
# ========================================

# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Save logs to file
LOG_TO_FILE=true

# ========================================
# Notes
# ========================================
# 
# Windows - Set environment variable:
#   setx GEMINI_API_KEY "your_api_key_here"
#
# Linux/Mac - Set environment variable:
#   export GEMINI_API_KEY="your_api_key_here"
#
# Atau gunakan file .env ini dengan python-dotenv
#
